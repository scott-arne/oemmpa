OC=O                                                     Formate
CC(=O)O                                                  Acetate
CCC(=O)O                                                 Propionate
CCCC(=O)O                                                Butyrate
CCCCCCCCCCCC(=O)O                                        Laurate (C12)
CCCCCCCCCCCCCCCC(=O)O                                    Palmitate (C16)
CCCCCCCCCCCCCCCCCC(=O)O                                  Stearate (C18)
CCCCCCCCC=CCCCCCCCC(=O)O                               Oleate (C18:1)
C=CCCCCCCCCC(=O)O                                        Undecylenate
OC(=O)C(F)(F)F                                           Trifluoroacetate (TFA)
OC(=O)C(Cl)(Cl)Cl                                        Trichloroacetate
OC(=O)C(Cl)Cl                                            Dichloroacetate
CC(O)C(=O)O                                              Lactate
OCC(=O)O                                                 Glycolate
CC(=O)C(=O)O                                             Pyruvate
OCC(O)C(O)C(O)C(O)C(=O)O                                 Gluconate
OC1OC(C(=O)O)C(O)C(O)C1O                                 Glucuronate

