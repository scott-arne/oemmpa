OC(=O)c1ccccc1                                           Benzoate
OC(=O)c1ccccc1O                                          Salicylate
OC(=O)c1cccnc1                                           Nicotinate
OC(=O)c1ccncc1                                           Isonicotinate
OC(=O)C(O)c1ccccc1                                       Mandelate
